<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<packageSources>
		<add key="PrivateGitHubNugets" value="https://nuget.pkg.github.com/SkylineCommunications/index.json" />
		<add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
	</packageSources>

	<packageSourceMapping>
		<!-- Only these packages come from Local Build Output -->
		<packageSource key="PrivateGitHubNugets">
			<package pattern="Skyline.DataMiner.Dev.Utils.Solutions.Relationships.*" />
		</packageSource>

		<!-- Everything else comes from nuget.org -->
		<packageSource key="nuget.org">
			<package pattern="*" />
		</packageSource>
	</packageSourceMapping>
</configuration>